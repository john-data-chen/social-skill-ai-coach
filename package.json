{
  "name": "social-skill-ai-coach",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "jianan.chen",
    "url": "https://github.com/john-data-chen/social-skill-ai-coach"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm typecheck && next build",
    "commit": "git-cz",
    "dev": "next dev",
    "format": "oxfmt --no-error-on-unmatched-pattern --config ./.oxfmtrc.json",
    "lint": "oxlint src packages/social-skills-coach-mcp/src --type-aware --fix --no-error-on-unmatched-pattern",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi",
    "start": "next start",
    "test": "vitest run && pnpm --filter social-skills-coach-mcp test",
    "test:coverage": "vitest run --coverage && pnpm --filter social-skills-coach-mcp test:coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.3",
    "@ai-sdk/react": "^4.0.12",
    "@base-ui/react": "^1.6.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@vercel/analytics": "^2.0.1",
    "ai": "^7.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "mcp-handler": "^1.1.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-textarea-autosize": "^8.5.9",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/cz-commitlint": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "commitizen": "^4.3.2",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "{src/!(components)/**/*.{js,jsx,ts,tsx,css,scss},src/components/!(ui)/**/*.{js,jsx,ts,tsx,css,scss}}": [
      "oxfmt --no-error-on-unmatched-pattern --config ./.oxfmtrc.json"
    ],
    "{src/!(components)/**/*.{js,jsx,ts,tsx},src/components/!(ui)/**/*.{js,jsx,ts,tsx}}": [
      "oxlint --type-aware --fix --no-error-on-unmatched-pattern"
    ],
    "packages/social-skills-coach-mcp/**/*.{js,jsx,ts,tsx,mjs,css,scss}": [
      "oxfmt --no-error-on-unmatched-pattern --config ./.oxfmtrc.json"
    ],
    "packages/social-skills-coach-mcp/**/*.{js,jsx,ts,tsx,mjs}": [
      "oxlint --type-aware --fix --no-error-on-unmatched-pattern"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}