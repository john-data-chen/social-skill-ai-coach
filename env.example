# Social Skills AI Coach - Environment Variables
# Copy this file to .env and fill in the values below to use the "Demo (Server Key)" mode.

# Xiaomi MiMo API Key
MIMO_API_KEY="your_mimo_api_key_here"
# You have to change the base url according to your own subscription plan.
MIMO_API_BASE_URL="https://token-plan-cn.xiaomimimo.com/v1"

# DeepSeek API Key
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# Grok API Key
GROK_API_KEY="your_grok_api_key_here"
