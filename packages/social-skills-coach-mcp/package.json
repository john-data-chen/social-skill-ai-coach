{
  "name": "social-skills-coach-mcp",
  "version": "1.0.11",
  "description": "MCP server for a social-skills coaching curriculum — knowledge tools + analyze/coach/roleplay/reflect prompts. Bring your own model.",
  "keywords": [
    "agent",
    "coaching",
    "mcp",
    "model-context-protocol",
    "social-skills"
  ],
  "license": "MIT",
  "author": "jianan.chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/john-data-chen/social-skill-ai-coach.git",
    "directory": "packages/social-skills-coach-mcp"
  },
  "bin": {
    "social-skills-coach-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "README-cht.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/server.js"
  },
  "scripts": {
    "build": "pnpm sync-skill && tsup",
    "prepack": "pnpm build",
    "sync-skill": "node scripts/sync-skill.mjs",
    "test": "pnpm sync-skill && vitest run",
    "test:coverage": "pnpm sync-skill && vitest run --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}
